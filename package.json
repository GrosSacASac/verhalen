{
  "name": "verhalen",
  "version": "3.0.0",
  "description": "Schema based database for JS",
  "license": "MIT",
  "type": "module",
  "main": "verhalen.js",
  "scripts": {
    "test": "node --test --test-global-setup ./tests/end_to_end/setup_teardown.js",
    "test-unit": "node --test \"tests/unit/**.test.js\"",
    "test-end_to_end": "node --test \"tests/end_to_end/**.test.js\"",
    "run": "node ./beispill.js",
    "lint-fix": "eslint --ignore-path .gitignore --fix",
    "lint": "eslint --ignore-path .gitignore"
  },
  "devDependencies": {
    "eslint": "^10.2.1",
    "eslint-config-red": "^1.9.1"
  },
  "eslintConfig": {
    "extends": ["red"],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module",
      "ecmaFeatures": {}
    },
    "env": {
      "es2026": true,
      "browser": true,
      "node": true
    },
    "rules": {}
  },
  "files": [
    "README.MD",
    "verhalen.js",
    "read.js",
    "write.js",
    "netzlech.js",
    "configuration.js"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/GrosSacASac/verhalen.git"
  },
  "keywords": ["database", "schema"]
}
